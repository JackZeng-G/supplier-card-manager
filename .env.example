# 服务器配置
SERVER_PORT=8080
DATABASE_PATH=/app/data/suppliers.db
TEMP_UPLOAD_PATH=/app/data/uploads
IMAGE_PATH=/app/data/images

# 腾讯云OCR配置
# 请在启动Docker前设置环境变量，或修改docker-compose.yml
# Windows: $env:TENCENT_SECRET_ID="your_id"
# Linux/Mac: export TENCENT_SECRET_ID="your_id"
TENCENT_SECRET_ID=your_secret_id_here
TENCENT_SECRET_KEY=your_secret_key_here
